# Harpa Gaming — Environment Variables Example
# Copy this file to .env and configure for your local/production environment
# Do NOT commit the actual .env file to source control.

# ─── Public Variables (Vite Built) ─────────────────
VITE_SITE_URL=https://your-netlify-domain.netlify.app
VITE_API_URL=/api

# ─── Secret Variables (Backend / Build only) ───────
# Define any secrets needed for form handling, analytics, or APIs below.
# Example: 
# SMTP_PASSWORD=your_secure_app_password
# API_SECRET_KEY=your_secret_key
